   "source": [
    "PYTHON BITWISE OPERATOR"
   ]
  },
  {
   "cell_type": "raw",
   "id": "d7c8742a-4f94-4164-aed2-f64b6761c50c",
   "metadata": {},
   "source": [
    "=> BITWISE LEFT SHIFT OPERATOR--->  SYMBOL= <<   (we gain the no. of 0 bits)\n",
    "=> BITWISE RIGHT SHIFT OPERATOR---> SYMBOL= >>   (we loose the no. of 0 bits)\n",
    "=> BITWISE AND OPERATOR-----------> SYMBOL= &    (1&1=1 else 0)\n",
    "=> BITWISE OR OPERATOR------------> SYMBOL= |    (0|0=0  else 1)\n",
    "=> BITWISE COMPLEMENT OPERATOR----> SYMBOL= ~    (-{value-1})\n",
    "=> BITWISE XOR OPERATOR-----------> SYMBOL= ^    (0^0=1^1=0  else 1)"
   ]
  },
